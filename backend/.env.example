# Application
APP_NAME=StellaServe
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./stellaserve.db

# JWT Auth
SECRET_KEY=your-secret-key-change-in-production
