# ═══════════════════════════════════════════════
#  StellaServe — Monorepo .gitignore
# ═══════════════════════════════════════════════

# ─── Common ───────────────────────────────────
.DS_Store
Thumbs.db
*.log
*.lock
!package-lock.json
.env
.env.local
.env.*.local

# ─── Node / JavaScript ───────────────────────
node_modules/
dist/
build/
.cache/
coverage/
*.tgz

# ─── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
venv/
.venv/
env/
.env/
*.db
*.sqlite3

# ─── Expo / React Native ─────────────────────
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# iOS
ios/Pods/
ios/build/
ios/*.xcworkspace/xcuserdata/

# Android
android/.gradle/
android/app/build/
android/build/
android/local.properties

# ─── Next.js ──────────────────────────────────
.next/
out/
.vercel

# ─── IDE ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Docker ───────────────────────────────────
docker-compose.override.yml